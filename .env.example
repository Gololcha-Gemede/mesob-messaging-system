# Database (required)
DB_HOST=127.0.0.1
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=imms_db

# Auth (required)
JWT_SECRET=change_this_to_a_long_random_string

# Server
PORT=5000
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173
CSP_CONNECT_SRC=http://localhost:5000 http://127.0.0.1:5000
UPLOAD_DIR=uploads

# Client / Vite
VITE_DEV_HOST=127.0.0.1
VITE_DEV_PORT=5173
VITE_PROXY_TARGET=http://localhost:5000
# Leave blank to use same-origin API calls through the Vite proxy in development.
VITE_API_BASE_URL=

# Set to true only if you want open self-registration at POST /api/auth/register
ALLOW_PUBLIC_REGISTER=false
